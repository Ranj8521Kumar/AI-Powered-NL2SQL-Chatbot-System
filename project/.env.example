# ── Copy this file to .env and fill in your values ───────────────────────────

# ── Primary LLM: Groq ─────────────────────────────────────────────────────────
# Get your free key at https://console.groq.com
# Free tier: 100,000 tokens/day (resets at midnight UTC)
GROQ_API_KEY=your-groq-api-key-here

# Groq model to use (free tier options):
#   llama-3.3-70b-versatile   <- recommended (fast, smart)
#   llama3-8b-8192            <- faster, smaller
#   mixtral-8x7b-32768        <- good for SQL tasks
GROQ_MODEL=llama-3.3-70b-versatile

# ── Fallback LLM: Google Gemini ───────────────────────────────────────────────
# Automatically used when Groq hits its daily token limit (429 error)
# Get your free key at https://aistudio.google.com/apikey
# Free tier: 1,500 requests/day, 1M tokens/day
GOOGLE_API_KEY=your-google-api-key-here

# Gemini model to use (free tier options):
#   gemini-2.0-flash          <- recommended (fast, generous quota)
#   gemini-1.5-flash          <- good alternative
GEMINI_MODEL=gemini-2.0-flash

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./clinic.db

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
